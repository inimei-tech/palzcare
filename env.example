# PalzCare — Environment Variables
# Kopiere diese Datei als .env und fülle die Werte aus
# NIEMALS die echte .env in Git committen

# App
APP_URL=https://app.palzcare.de
NODE_ENV=development

# Supabase (Datenbank)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth / SMS
SMS_PROVIDER_API_KEY=

# Stripe (Zahlung, Phase 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Proton Mail / SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# n8n Automatisierung
N8N_WEBHOOK_URL=
